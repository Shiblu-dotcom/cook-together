# Copy this file to ".env" (no extension) and replace the value below with
# your real Anthropic API key. You can create a key at:
#   https://console.anthropic.com/settings/keys
#
# Without a real key, the app still runs — it just uses canned fallback
# responses instead of personalised AI judging.
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
